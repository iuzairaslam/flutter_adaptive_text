{
  "name": "react-native-adaptive-text",
  "version": "1.0.0",
  "description": "Picks a legible text color from a background (WCAG 2.1 + optional APCA). AdaptiveText, context theme, zero native code.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "typescript": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "react-native",
    "accessibility",
    "wcag",
    "contrast",
    "apca",
    "text",
    "color"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iuzairaslam/flutter_adaptive_text.git",
    "directory": "PLUGINS/react-native-adaptive-text"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.55",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
